DATABASE_URL=postgresql+psycopg://sar:sar@localhost:5432/sourcealignrec

# ── Model Pool providers (model-pool.yaml endpoint env) ──
LMSTUDIO_BASE_URL=http://localhost:12345/v1
LMSTUDIO_API_KEY=lm-studio
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_API_KEY=
CHATKHU_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
CHATKHU_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# ── API auth ──
# 배포 시 강한 랜덤 필수. 미설정 시 config.py의 공개 default로 fallback → JWT 위조 위험.
# 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
SAR_JWT_SECRET=

# ── CORS ──
# 배포 시 프론트(Vercel) 도메인 추가. 콤마 구분. 미설정 시 config default(localhost).
SAR_CORS_ORIGINS=https://<your-app>.vercel.app

# ── 추천 모델 (선택 override) ──
# default = google/gemini-3.1-flash-lite. 배포 환경에서 불만족 시 여기서 교체.
# API_RECOMMEND_MODEL=
